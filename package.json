{
  "name": "n8n-automation",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "docker:start": "docker compose -f docker/docker-compose.dev.yml up -d",
    "docker:stop": "docker compose -f docker/docker-compose.dev.yml down",
    "docker:log": "docker compose -f docker/docker-compose.dev.yml logs -f",
    "docker:rebuild": "docker compose -f docker/docker-compose.dev.yml up -d --build",
    "local": "bun run docker:start && turbo dev",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "packageManager": "bun@1.3.12",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@ai-sdk/google": "^3.0.64"
  }
}