// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String    @id @default(cuid())
  userName                 String
  email                    String    @unique
  avatarUrl                String?
  passwordHash             String
  isEmailVerified          Boolean   @default(false)
  isArchived               Boolean   @default(false)
  passwordResetTokenHash   String?
  passwordResetTokenExpiry DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  projects                 Project[]
}

model PendingUser {
  id           String   @id @default(cuid())
  userName     String
  email        String   @unique
  passwordHash String
  otpHash      String
  otpExpiry    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum ProjectType {
  PERSONAL
  TEAM
}

model Project {
  id          String      @id @default(cuid())
  name        String
  description String?
  type        ProjectType @default(PERSONAL)
  userId      String
  icon        Json? // Store icon as JSON (e.g., { "type": "emoji" | "image", "value": string }
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflows   Workflow[]
  credentials Credential[]

  @@index([userId])
}

model Workflow {
  id          String   @id @default(cuid())
  name        String
  description String?
  projectId   String
  active      Boolean  @default(false)
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  nodes      Node[]
  edges      Edge[]
  executions Execution[]
  webhooks   Webhook[]

  @@index([projectId])
}

model Node {
  id           String  @id @default(cuid())
  name         String
  type         String
  description  String?
  parameters   Json
  positionX    Int
  positionY    Int
  data         Json?
  workflowId   String
  credentialId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workflow   Workflow    @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  credential Credential? @relation(fields: [credentialId], references: [id])

  outEdges Edge[] @relation("SourceNode")
  inEdges  Edge[] @relation("TargetNode")

  @@index([workflowId])
}

model Edge {
  id           String   @id @default(cuid())
  source       String
  target       String
  workflowId   String
  sourceHandle String?
  targetHandle String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  sourceNode Node     @relation("SourceNode", fields: [source], references: [id], onDelete: Cascade)
  targetNode Node     @relation("TargetNode", fields: [target], references: [id], onDelete: Cascade)

  @@index([workflowId])
}

model Credential {
  id        String   @id @default(cuid())
  name      String
  type      String
  data      Json
  projectId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  nodes   Node[]

  @@index([projectId])
}

enum ExecutionStatus {
  CANCELLED
  CRASHED
  ERROR
  STARTING
  SUCCESS
  RUNNING
  FINISHED
}

model Execution {
  id         String          @id @default(cuid())
  workflowId String
  status     ExecutionStatus @default(STARTING)
  isFinished Boolean         @default(false)
  result     Json?
  data       Json?
  createdAt  DateTime        @default(now())
  startedAt  DateTime?
  stoppedAt  DateTime?

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([workflowId, createdAt])
}

model Webhook {
  id      String  @id @default(cuid())
  url     String  @unique
  method  String?
  headers Json?
  body    Json?

  workflowId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
}
